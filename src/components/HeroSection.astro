---
import { getTranslations } from '../i18n'
import LinkButton from './LinkButton.astro'

const currentLocale = Astro.currentLocale || 'es'
const t = getTranslations(currentLocale)
---

<section
  id='home'
  class='hero-section min-h-screen w-full flex gap-20 flex-col-reverse lg:flex-row items-center justify-center px-10 md:px-32 py-12 pt-16 md:pt-12 bg-[#0d1117] text-white overflow-hidden relative'
>
  <!-- Fondo de partículas CSS -->
  <div class='hero-bg' aria-hidden='true'>
    <div class='particle p1'></div>
    <div class='particle p2'></div>
    <div class='particle p3'></div>
    <div class='particle p4'></div>
    <div class='particle p5'></div>
    <div class='particle p6'></div>
    <div class='glow-orb orb1'></div>
    <div class='glow-orb orb2'></div>
  </div>

  <!-- Texto -->
  <article class='hero-text lg:w-2/5 text-center md:text-left relative z-10'>
    <p class='hero-line hero-line-1 text-sm font-semibold uppercase tracking-widest text-blue-400 mb-2'>
      {t.hero.greeting}
    </p>
    <h1 class='hero-line hero-line-2 text-4xl md:text-6xl font-bold mb-4'>
      <span class='text-white'>Elizon </span><span class='text-blue-400'>Rodriguez</span>
    </h1>
    <p class='hero-line hero-line-3 text-sm font-semibold uppercase tracking-widest text-blue-400 mb-4' data-i18n='hero.title'>
      {t.hero.title}
    </p>
    <p
      class='hero-line hero-line-4 text-lg md:text-xl mb-6 max-w-md mx-auto md:mx-0 leading-relaxed'
      data-i18n='hero.description'
      set:html={t.hero.description}
    />
    <div class='hero-line hero-line-5 flex flex-col sm:flex-row gap-4 justify-center md:justify-start'>
      <LinkButton
        href={currentLocale === 'es' ? '#projects' : '/en#projects'}
        style='text-white bg-blue-600 border-blue-600 hover:text-white hover:bg-blue-700 hover:border-blue-700 dark:text-white dark:bg-blue-600 dark:border-blue-600'
        data-i18n-btn='projects.title'
      >
        {t.projects.title}
      </LinkButton>
      <LinkButton
        href={currentLocale === 'es' ? 'https://cv.elizonrodriguez.com/' : 'https://cv.elizonrodriguez.com/en'}
        target='_blank'
        rel='noopener noreferrer'
        style='border-gray-300 hover:bg-white hover:text-black hover:border-gray-400 dark:border-gray-600 dark:hover:bg-gray-700 dark:hover:text-white dark:hover:border-gray-500'
        data-i18n-btn='hero.downloadCV'
      >
        {t.hero.downloadCV}
      </LinkButton>
    </div>
  </article>

  <!-- Imagen -->
  <div class='hero-image lg:w-2/5 mb-8 md:mb-0 flex flex-col justify-center items-center relative z-10'>
    <div class='absolute inset-0 w-72 h-72 mx-auto'>
      <svg class='tech-logo tech-logo-1 absolute w-10 h-10' fill='currentColor'>
        <use href='/assets/sprite.svg#react'></use>
      </svg>
      <svg class='tech-logo tech-logo-2 absolute w-10 h-10' fill='currentColor'>
        <use href='/assets/sprite.svg#html5'></use>
      </svg>
      <svg class='tech-logo tech-logo-3 absolute w-10 h-10' fill='currentColor'>
        <use href='/assets/sprite.svg#css'></use>
      </svg>
      <svg class='tech-logo tech-logo-4 absolute w-10 h-10' fill='currentColor'>
        <use href='/assets/sprite.svg#javascript'></use>
      </svg>
    </div>

    <img
      src='/img/elizonperfil.webp'
      alt='Avatar de Elizon'
      class='w-72 h-72 object-cover overflow-hidden rounded-full shadow-lg justify-center items-center border-4 border-blue-500 relative z-10'
    />

    <div class='flex flex-col items-center justify-center mt-4'>
      <span
        class='text-whitetext-gray-400 text-xl font-semibold text-center items-center'
        data-i18n='contact.contacts'
        >{t.contact.contacts}</span
      >
      <div class='flex gap-2 mt-4'>
        <a
          href='https://github.com/elizonRL'
          target='_blank'
          title='Ir a GitHub'
          class='flex size-12 rounded-full border-white border-1 justify-center items-center transition duration-150 hover:translate-y-1 hover:scale-110'
        >
          <svg width='20' height='20' fill='black'>
            <use href='/assets/sprite.svg#github'></use>
          </svg>
          <a
            href='https://www.linkedin.com/in/elizonrodriguez/'
            class='flex size-12 rounded-full border-white border-1 justify-center items-center hover:scale-110 transition duration-150 hover:translate-y-1'
            target='_blank'
            title='Ir a linkedin'
          >
            <svg width='20' height='20' fill='currentColor'>
              <use href='/assets/sprite.svg#linkedin'></use>
            </svg>
          </a>
          <a
            href='mailto:elizorodriguez16@gmail.com'
            target='_blank'
            class='flex size-12 rounded-full border-white border-1 justify-center items-center hover:scale-110 transition duration-150 hover:translate-y-1'
            title='Contactar por Gmail'
          >
            <svg width='20' height='20' fill='currentColor'>
              <use href='/assets/sprite.svg#mail'></use>
            </svg>
          </a>
        </a>
      </div>
    </div>
  </div>

  <svg
    class='w-8 h-8 text-blue-500 arrow-down absolute bottom-10 left-1/2 transform -translate-x-1/2 z-10 hidden md:block'
    fill='currentColor'
  >
    <use href='/assets/sprite.svg#arrow-down'></use>
  </svg>
</section>

<style>
  .hero-line, .hero-image, .tech-logo { opacity: 0; }

  .hero-bg {
    position: absolute; inset: 0;
    pointer-events: none; overflow: hidden;
  }
  .glow-orb {
    position: absolute; border-radius: 50%;
    filter: blur(80px); opacity: 0;
  }
  .orb1 {
    width: 400px; height: 400px;
    background: radial-gradient(circle, rgba(59,130,246,0.18) 0%, transparent 70%);
    top: -100px; left: -100px;
  }
  .orb2 {
    width: 350px; height: 350px;
    background: radial-gradient(circle, rgba(96,165,250,0.12) 0%, transparent 70%);
    bottom: -80px; right: -80px;
  }
  .particle {
    position: absolute; border-radius: 50%;
    background: rgba(96,165,250,0.6); opacity: 0;
  }
  .p1 { width:2px; height:2px; left:10%; top:20%; }
  .p2 { width:3px; height:3px; left:25%; top:70%; }
  .p3 { width:4px; height:4px; left:60%; top:15%; background:rgba(147,197,253,0.4); }
  .p4 { width:2px; height:2px; left:75%; top:60%; }
  .p5 { width:3px; height:3px; left:85%; top:30%; }
  .p6 { width:2px; height:2px; left:45%; top:80%; background:rgba(147,197,253,0.3); }

  .tech-logo-1 { top:-5%;    right:-5%;  z-index:1; }
  .tech-logo-2 { top:35%;    left:-15%;  z-index:1; }
  .tech-logo-3 { bottom:35%; right:-15%; z-index:1; }
  .tech-logo-4 { bottom:-5%; left:-5%;   z-index:1; }
  .tech-logo:hover { transform: scale(1.15) rotate(8deg); transition: transform 0.3s ease; }
</style>
