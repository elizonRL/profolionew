---
import { getTranslations } from '../i18n';
import ExperienceCard from './experienceCard.astro';

const currentLocale = Astro.currentLocale || 'es';
const t = getTranslations(currentLocale);
const { experience } = t;
---

<section class="min-h-screen bg-[#0b0f17] px-4 md:px-8 py-12 text-white" id='experience'>
  <div class="max-w-5xl w-full mx-auto px-4 md:px-6">
    <div class="exp-header mb-16">
      <p class="exp-subtitle mb-2 text-xs font-bold uppercase tracking-widest text-blue-400">
        {experience.subtitle}
      </p>

      <h2 class="exp-title text-4xl font-extrabold tracking-tight md:text-5xl">
        {experience.title}
      </h2>

      <p class="exp-desc mt-3 max-w-2xl text-sm font-medium text-slate-300">
        {experience.description}
      </p>
    </div>

    <div class="relative">
      <div class="exp-line absolute left-1/2 top-0 hidden h-full w-px -translate-x-1/2 bg-blue-900/50 md:block"></div>
      <div class="absolute left-4 top-0 h-full w-px bg-blue-900/50 md:hidden"></div>

      <div class="space-y-2">
        {experience.jobs.map((job, index) => (
          <div class={`exp-row exp-row-${index} relative grid grid-cols-1 md:grid-cols-2 md:gap-10`}>
            <div class={`exp-dot absolute left-4 top-20 z-10 h-5 w-5 -translate-x-1/2 rounded-full md:left-1/2 ${index === 0 ? 'animate-pulse border-2 border-blue-400 bg-blue-500 shadow-[0_0_20px_rgba(96,165,250,0.6)]' : 'bg-blue-900 border-2 border-blue-700 shadow-[0_0_10px_rgba(59,130,246,0.3)]'}`}></div>
            
            {index % 2 === 0 ? (
              <>
                <ExperienceCard>
                  <span slot="period">{job.period}</span>
                  <span slot="title">{job.title}</span>
                  <span slot="company">{job.company}</span>
                  <Fragment slot="highlights">
                    {job.highlights.map((highlight, hIndex) => (
                      <li class="flex gap-3">
                        <span class={`mt-1 h-3 w-3 shrink-0 rounded-full border-2 ${highlight.highlighted ? 'border-blue-400 bg-blue-500 shadow-[0_0_12px_rgba(96,165,250,0.8)]' : 'border-blue-700/50 bg-blue-900/30'}`}></span>
                        <span>{highlight.text}</span>
                      </li>
                    ))}
                  </Fragment>
                  <Fragment slot="technologies">
                    {job.technologies.map((tech) => (
                      <span class="rounded-full bg-[#111827] px-3 py-1 text-xs text-blue-300">{tech}</span>
                    ))}
                  </Fragment>
                </ExperienceCard>
                <div class="hidden md:block"></div>
              </>
            ) : (
              <>
                <div class="hidden md:block"></div>
                <ExperienceCard>
                  <span slot="period">{job.period}</span>
                  <span slot="title">{job.title}</span>
                  <span slot="company">{job.company}</span>
                  <Fragment slot="highlights">
                    {job.highlights.map((highlight) => (
                      <li class="flex gap-3">
                        <span class={`mt-1 h-3 w-3 shrink-0 rounded-full border-2 ${highlight.highlighted ? 'border-blue-400 bg-blue-500 shadow-[0_0_12px_rgba(96,165,250,0.8)]' : 'border-blue-700/50 bg-blue-900/30'}`}></span>
                        <span>{highlight.text}</span>
                      </li>
                    ))}
                  </Fragment>
                  <Fragment slot="technologies">
                    {job.technologies.map((tech) => (
                      <span class="rounded-full bg-[#111827] px-3 py-1 text-xs text-blue-300">{tech}</span>
                    ))}
                  </Fragment>
                </ExperienceCard>
              </>
            )}
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
