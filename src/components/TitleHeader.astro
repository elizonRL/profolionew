---
const { titleH2, i18nKey, subtitle, description } = Astro.props;
---

<div class="mb-16">
  {subtitle && (
    <p class="mb-2 text-xs font-bold uppercase tracking-widest text-blue-400">{subtitle}</p>
  )}
  <h2 class="text-4xl font-extrabold tracking-tight md:text-5xl">
    <span data-i18n-title={i18nKey}>{titleH2}</span>
  </h2>
  {description && (
    <p class="mt-3 max-w-2xl text-sm font-medium text-slate-300">{description}</p>
  )}
</div>