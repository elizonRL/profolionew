---
import { getTranslations } from '../i18n';
const currentLocale = Astro.currentLocale || 'es'

const t = getTranslations(currentLocale); 

---
<div class="ml-10 md:ml-0">
            <article class="w-full rounded-lg bg-[#242933] p-6 shadow-xl md:max-w-md">
              <span class="text-xs font-bold text-blue-400">2020 - Present</span>

              <h3 class="mt-2 text-xl font-bold text-blue-300">
                Senior Full Stack Developer
              </h3>

              <p class="mt-1 text-sm font-semibold text-white">
                Tech Innovations Inc.
              </p>

              <ul class="mt-5 space-y-4 text-sm text-slate-200">
                <li class="flex gap-3">
                  <span class="mt-1 h-3 w-3 shrink-0 rounded-full border border-blue-300 bg-blue-400 shadow-[0_0_14px_rgba(96,165,250,1)]"></span>
                  <span>
                    Architected and deployed a microservices ecosystem serving
                    1M+ active monthly users using Node.js and AWS.
                  </span>
                </li>

                <li class="flex gap-3">
                  <span class="mt-1 h-3 w-3 shrink-0 rounded-full border border-blue-400/50 bg-blue-400/20"></span>
                  <span>
                    Mentored a cross-functional team of 12 engineers, improving
                    deployment velocity by 40%.
                  </span>
                </li>
              </ul>

              <div class="mt-5 flex flex-wrap gap-2">
                <span class="rounded-full bg-[#111827] px-3 py-1 text-xs text-blue-300">React</span>
                <span class="rounded-full bg-[#111827] px-3 py-1 text-xs text-blue-300">Node.js</span>
                <span class="rounded-full bg-[#111827] px-3 py-1 text-xs text-blue-300">AWS</span>
              </div>
            </article>
          </div>

          <div class="hidden md:block"></div>
        </div>