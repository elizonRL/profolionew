---
import '../styles/global.css';
import '../styles/transitions.css';
import Header from '@/Header.astro';
import { ClientRouter } from 'astro:transitions';

const { title, description } = Astro.props;
const currentLocale = Astro.currentLocale || 'es';
---

<!doctype html>
<html lang={currentLocale}>
	<head>
		<meta charset='UTF-8' />
		<meta
			name='viewport'
			content='width=device-width'
		/>
		<meta name="google-site-verification" content="PnxyMy9T36Cj8BrAhoDNcbXnKbtb2s7xwG_5mBDgf3w" />
		<link
			rel='icon'
			type='image/svg+xml'
			href='/favicon.svg'
		/>
		<meta
			name='description'
			content={description}>
		<meta
			name='generator'
			content={Astro.generator}
		/>
		<title>{title}</title>
		<ClientRouter />
		<script src="/src/scripts/i18n-init.ts"></script>
		<script>
			import { gsap } from 'gsap';
			import { ScrollTrigger } from 'gsap/ScrollTrigger';
			import { initAnimations } from '../scripts/animations';
			gsap.registerPlugin(ScrollTrigger);

			document.addEventListener('astro:before-swap', () => {
				ScrollTrigger.getAll().forEach(t => t.kill());
				gsap.killTweensOf('*');
			});

			document.addEventListener('astro:page-load', () => {
				const fromOtherPage = !window.location.hash;
				if (fromOtherPage) window.scrollTo(0, 0);

				initAnimations();

				setTimeout(() => ScrollTrigger.refresh(), 200);
			});

			document.addEventListener('click', (e) => {
				const link = (e.target as HTMLElement).closest('a[href^="#"]');
				if (!link) return;
				setTimeout(() => {
					ScrollTrigger.refresh();
					ScrollTrigger.getAll().forEach(trigger => {
						const el = trigger.trigger;
						if (!el) return;
						const rect = el.getBoundingClientRect();
						if (rect.top < window.innerHeight && rect.bottom > 0) {
							trigger.animation?.progress(1).pause();
						}
					});
				}, 600);
			});
		</script>
	</head>
	<body >
		<Header/>
			<slot />
	</body>
</html>

<style>
	@reference "../styles/global.css";
	html,
	body {
		color: white;
		margin: 0;
		width: 100%;
		height: 100%;
		overflow-x: hidden;
		@apply m-auto bg-[#0d1117];
		scroll-behavior: smooth;
	}
</style>
